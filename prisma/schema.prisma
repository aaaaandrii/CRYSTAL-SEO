generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Auth ──────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("editor") // "admin" | "editor"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── CMS Content ──────────────────────────────────────────────────────
// Stores page section content as JSON (hero text, CTA copy, etc.)
model PageContent {
  id        String   @id @default(cuid())
  page      String   // "home", "technology", "about", etc.
  section   String   // "hero", "swiss-made", "cta", etc.
  content   String   // JSON blob with all section fields
  updatedAt DateTime @updatedAt

  @@unique([page, section])
}

// Stores list-based content items (FAQ, sectors, benefits, etc.)
model ContentItem {
  id        String   @id @default(cuid())
  type      String   // "faq", "benefit", "process-step", "sector", etc.
  data      String   // JSON blob with type-specific fields
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, sortOrder])
}

// ── Existing Content ─────────────────────────────────────────────────
model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  imageUrl    String
  imageAlt    String    @default("")
  published   Boolean   @default(false)
  publishedAt DateTime?
  source      String?
  sourceName  String?
  tags        String    @default("")
  authorId    String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
}

model CaseStudy {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  client      String
  sector      String
  excerpt     String
  challenge   String
  solution    String
  outcome     String
  content     String
  imageUrl    String
  imageAlt    String    @default("")
  logoUrl     String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
  @@index([sector])
}
